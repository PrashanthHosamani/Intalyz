# ─────────────────────────────────────────────────────────────────────────────
#  OSINT Tool — Environment Configuration
#  Copy this file as .env and fill in your API keys
# ─────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────────────────
# 1. EXTERNAL API KEYS
# ──────────────────────────────────────────────────────────────────────────────

# GitHub Personal Access Token (for GitHubAdapter)
# Generate at: https://github.com/settings/tokens
# Required scopes: public_repo, read:user, read:org
GITHUB_TOKEN=

# Have I Been Pwned API Key (for ContextualAdapter — breach detection)
# Free tier available at: https://haveibeenpwned.com/API/v3
HIBP_API_KEY=

# NewsAPI Key (for ContextualAdapter — news mentions)
# Free tier at: https://newsapi.org/
NEWS_API_KEY=

# OpenCorporates API Token (for ContextualAdapter — corporate registry)
# Free tier at: https://opencorporates.com/api
OPENCORPORATES_TOKEN=

# SecurityTrails API Key (DNS history, future expansion)
# Premium service: https://securitytrails.com/
SECURITYTRAILS_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# 2. OPSEC & PROXY SETTINGS
# ──────────────────────────────────────────────────────────────────────────────

# Enable proxy rotation for OPSEC
# false = direct requests, true = rotate through PROXY_LIST
USE_PROXIES=false

# Proxy list (comma-separated URLs)
# Format: http://user:pass@host:port or https://host:port
# Example: http://proxy1.com:8080,http://proxy2.com:8080
PROXY_LIST=

# Proxy rotation interval (seconds between rotations)
# Only used if USE_PROXIES=true
PROXY_ROTATION_INTERVAL=60

# Enable request randomization (user agents, headers, delays)
RANDOMIZE_REQUESTS=true

# ──────────────────────────────────────────────────────────────────────────────
# 3. RATE LIMITING & TIMEOUTS
# ──────────────────────────────────────────────────────────────────────────────

# Global HTTP request timeout (seconds)
DEFAULT_TIMEOUT=15

# Default rate limit between requests (seconds)
# Applied per adapter, prevents rapid-fire requests
DEFAULT_RATE_LIMIT=2.0

# Max retry attempts for failed requests (with exponential backoff)
MAX_RETRIES=3

# Per-adapter rate limits (seconds between requests)
# Leave blank to use DEFAULT_RATE_LIMIT
GOOGLE_DORK_RATE_LIMIT=
WHOIS_DNS_RATE_LIMIT=1.0
GITHUB_RATE_LIMIT=2.0
CONTEXTUAL_RATE_LIMIT=3.0

# ──────────────────────────────────────────────────────────────────────────────
# 4. OUTPUT & LOGGING
# ──────────────────────────────────────────────────────────────────────────────

# Output directory (absolute path recommended)
# Reports, JSON dumps, and logs will be saved here
OUTPUT_DIR=/Users/apple/Downloads/OSINT/output

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable file logging (in addition to console)
FILE_LOGGING=true

# ──────────────────────────────────────────────────────────────────────────────
# 5. ADAPTER-SPECIFIC LIMITS
# ──────────────────────────────────────────────────────────────────────────────

# Google Dork adapter — max results per query
GOOGLE_DORK_MAX_RESULTS_PER_QUERY=5

# GitHub adapter — max repos and orgs to fetch
GITHUB_MAX_REPOS=10
GITHUB_MAX_ORGS=3

# Contextual adapter — max news articles and breaches
CONTEXTUAL_MAX_NEWS_ARTICLES=10
CONTEXTUAL_MAX_BREACHES=5

# WHOIS/DNS — max candidate domains to check
WHOIS_DNS_MAX_DOMAINS=6

# ──────────────────────────────────────────────────────────────────────────────
# 6. ENTITY RESOLUTION & RISK SCORING
# ──────────────────────────────────────────────────────────────────────────────

# Confidence score threshold for a finding to be "confirmed" (0-100)
# Below this threshold → flagged as potential false positive
CONFIDENCE_THRESHOLD=60

# Enable advanced NER-based entity linking (requires spacy)
# Set to false if spacy model not installed
USE_NER_LINKING=true

# ──────────────────────────────────────────────────────────────────────────────
# 7. DJANGO WEB APP (osint_web)
# ──────────────────────────────────────────────────────────────────────────────

# Django secret key (override in Django settings for production)
DJANGO_SECRET_KEY=your-secret-key-change-this-in-production

# Allowed hosts (comma-separated)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Debug mode (NEVER true in production)
DEBUG=false

# Database (if using real DB instead of SQLite)
DATABASE_URL=sqlite:///db.sqlite3
